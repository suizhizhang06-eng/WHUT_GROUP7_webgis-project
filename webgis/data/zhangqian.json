        "lng": 108.9391,
        "name": "长安"
      },
      "type": "departure",
      "description": "汉武帝为联合大月氏夹击匈奴，招募使者。张骞以郎官身份应募，率领百余人从长安出发。",
      "roles": ["zhangqian", "han-wudi"],
      "relatedEvents": ["event-02"],
      "routeId": "route-01"
    },
    {
      "id": "event-02",
