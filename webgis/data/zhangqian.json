{
  "narrative": {
    "id": "zhangqian-silk-road",
    "title": "张骞出使西域",
    "subtitle": "丝绸之路的开拓者",
    "description": "公元前138年，汉武帝派遣张骞出使西域，意图联合大月氏夹击匈奴。张骞历经13年艰辛，虽未完成最初使命，却开辟了举世闻名的丝绸之路，促进了东西方文明的交流与融合。",
    "timeRange": {
      "start": "前138年",
      "end": "前60年"
    }
  },
